{
    "manifest_version": 3,
    "name": "LinkedIn Access+",
    "version": "1.0",
    "description": "Accessibility layer for LinkedIn",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "sidePanel",
        "tabs"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "https://localhost:8000/*",
        "https://www.linkedin.com/*",
        "file:///*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open LinkedIn Access+ Panel"
    },
    "side_panel": {
        "default_path": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/*",
                "file:///*"
            ],
            "js": [
                "content/content.js"
            ],
            "run_at": "document_end"
        }
    ]
}